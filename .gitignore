# Python
__pycache__/
*.pyc
*.part

# Derivados (sempre reproduzíveis a partir de data/raw)
data/interim/
data/processed/

# Brutos GRANDES do TSE: não versionados para manter o repositório leve.
# São 100% reproduzíveis — o manifest/provenance.json guarda URL + SHA-256
# para rebaixar e conferir bytes idênticos. Ver README ("Procedência").
data/raw/tse/*.zip

# Mantemos versionados os brutos pequenos (crosswalk e respostas do IBGE),
# essenciais para reproduzir os números sem depender da rede.
!data/raw/crosswalk/
!data/raw/ibge/

# Scratch
tests/_*.py

# Config local de ferramentas de desenvolvimento (preview, permissões,
# caminhos absolutos da máquina). Não pertence ao repositório público.
.claude/
.vscode/
.idea/
